# Modèle de variables d'environnement pour Claude Code on the web.
#
# NE PAS committer de vraie clé. Copie ces paires dans le champ
# "Environment variables" de l'environnement (interface claude.ai/code) —
# format .env, une paire KEY=value par ligne, SANS guillemets (les guillemets
# sont stockés comme partie de la valeur).
#
# Rappel doc : il n'existe pas encore de coffre à secrets ; ces variables sont
# visibles par quiconque peut éditer l'environnement.

# Backend Claude (feature `llm-claude`) : clé API Anthropic.
ANTHROPIC_API_KEY=sk-ant-REMPLACE_MOI

# (optionnel) binaire externe pour PapersKnowledge (sinon dégradation propre).
# RSI_PAPERS_BIN=papers
